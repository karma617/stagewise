# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly LF for source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.sh   text eol=lf

# Binary files - no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.eot  binary
*.mp3  binary
*.mp4  binary
*.node binary
*.exe  binary
*.dll  binary